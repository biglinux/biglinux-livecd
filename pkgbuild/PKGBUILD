# Maintainer: Bruno Goncalves <bigbruno@gmail.com>
# shellcheck shell=bash disable=SC2034,SC2154

pkgname=biglinux-livecd
pkgver=26.07.11
pkgrel=1
pkgdesc="BigLinux live-session setup and Calamares installer integration"
arch=('any')
url="https://github.com/biglinux/biglinux-livecd"
license=('GPL-3.0-only' 'CC0-1.0')
depends=(
    'binutils'
    'btrfs-progs'
    'calamares'
    'circle-flags'
    'curl'
    'e2fsprogs'
    'gettext'
    'gtk4'
    'libadwaita'
    'mtools'
    'python'
    'python-babel'
    'python-gobject'
    'qefientrymanager'
    'util-linux'
)
optdepends=('speech-dispatcher: spoken feedback in the live-session wizard')
makedepends=('git')
source=("${pkgname}::git+${url}.git#commit=92c7b7463fcf504d1795c4e4bd2ecbd04a4a7f03")
sha256sums=('SKIP')
install="${pkgname}.install"

package() {
    cd "${srcdir}/${pkgname}" || return 1

    cp -a biglinux-livecd/usr "${pkgdir}/"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
